# ── Go ────────────────────────────────────────────────────────────────────────
bin/
*.exe
*.test
*.out
go/vendor/

# ── gomobile output ───────────────────────────────────────────────────────────
# The AAR is generated by the build workflow — never commit it.
# The workflow writes it to app/libs/ at build time.
android/app/libs/*.aar
android/app/libs/*.jar

# ── Android build output ──────────────────────────────────────────────────────
android/.gradle/
android/build/
android/app/build/
android/local.properties        # machine-specific SDK path, differs per developer
android/captures/
android/.externalNativeBuild/
android/.cxx/

# ── Gradle wrapper jar — KEEP gradlew and gradle-wrapper.properties ───────────
# The .jar is binary and large; regenerated by the wrapper automatically.
android/gradle/wrapper/gradle-wrapper.jar

# ── Keystore / signing ────────────────────────────────────────────────────────
*.jks
*.keystore
keystore.properties

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
